# Copy file này thành ".env" rồi điền giá trị từ:
#   Supabase Dashboard → Project Settings → API

# Dùng ở CLIENT (trình duyệt) — Vite chỉ expose biến tiền tố VITE_
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...   # "anon public" key

# CHỈ dùng cho script import (node) — TUYỆT ĐỐI không đưa vào client/bundle
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbG...     # "service_role" key (bí mật)
